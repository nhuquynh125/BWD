# ══════════════════════════════════════════════════════════
#  LUNAR HERITAGE v3 – Environment Variables Template
#  ✅  This file IS safe to commit to Git (no real secrets).
#  ⚠️  Copy this to ".env", fill in real values, and NEVER
#      commit your ".env" file.
# ══════════════════════════════════════════════════════════

# ── JWT Secret ──────────────────────────────────────────────
# Generate a strong random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── Server ──────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/lunar_heritage
# Cloud:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/lunar_heritage
MONGODB_URI=mongodb://localhost:27017/lunar_heritage

# ── Google Gemini API ────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite

# ── URLs (used by payment adapters for return/notify URLs) ──
# Set BACKEND_URL to your server's public URL in production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8000

# ── VNPay (sandbox) ──────────────────────────────────────────
# Sandbox portal: https://sandbox.vnpayment.vn/apis/
VNPAY_TMN_CODE=DEMO_TMN_CODE
VNPAY_HASH_SECRET=DEMO_VNPAY_HASH_SECRET_KEY_32CH
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/booking/payment/return/vnpay

# ── MoMo (sandbox) ───────────────────────────────────────────
# Sandbox portal: https://developers.momo.vn/
MOMO_PARTNER_CODE=MOMOBKUN20180529
MOMO_ACCESS_KEY=klm05TvNBzhg7h7j
MOMO_SECRET_KEY=at67qH6mk8w5Y1nAyMoTKAt67qH6mk8w
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8000/api/booking/payment/return/momo
MOMO_NOTIFY_URL=http://localhost:8000/api/booking/webhook/momo
